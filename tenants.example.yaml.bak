# Optional tenant list for AVoIPCollector / backend alignment.
# Use: avoip-load-generator -tenants-file tenants.example.yaml
#
# exporter_ip is used as the UDP source when the OS allows binding to it
# (typical on Linux with secondary addresses). On Windows, binding often
# fails unless those addresses exist locally; the tool falls back to a
# single socket and still varies NetFlow SourceId per tenant.
#
# If the file lists fewer entries than -tenants, remaining tenants get
# auto-generated IPs after the last configured address.

tenants:
  - id: b61cfc03-b6a7-4714-ab13-ad152feb99ce
    exporter_ip: 69.253.84.27